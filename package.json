{
  "name": "enterprise-agent-orchestration",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx apps/orchestrator/src/server.ts",
    "dev:compiled": "node dist/apps/orchestrator/src/server.js",
    "demo": "tsx apps/orchestrator/src/demo.ts",
    "outlook:poller": "tsx workers/outlook-worker/src/poller.ts",
    "outlook:poller:compiled": "node dist/workers/outlook-worker/src/poller.js",
    "test": "node scripts/run-tests.mjs",
    "win:setup": "powershell -ExecutionPolicy Bypass -File scripts/windows/setup.ps1",
    "win:start": "powershell -ExecutionPolicy Bypass -File scripts/windows/start-orchestrator.ps1",
    "win:poller": "powershell -ExecutionPolicy Bypass -File scripts/windows/start-poller.ps1",
    "win:start-all": "powershell -ExecutionPolicy Bypass -File scripts/windows/start-all.ps1",
    "win:doctor": "powershell -ExecutionPolicy Bypass -File scripts/windows/doctor.ps1",
    "win:health": "powershell -ExecutionPolicy Bypass -File scripts/windows/health.ps1",
    "win:sessions": "powershell -ExecutionPolicy Bypass -File scripts/windows/list-sessions.ps1",
    "win:create-shipment-case": "powershell -ExecutionPolicy Bypass -File scripts/windows/create-shipment-case.ps1",
    "win:advance-case": "powershell -ExecutionPolicy Bypass -File scripts/windows/advance-case.ps1",
    "win:approve-latest": "powershell -ExecutionPolicy Bypass -File scripts/windows/approve-latest.ps1",
    "win:llm:init": "powershell -ExecutionPolicy Bypass -File scripts/windows/init-llm-config.ps1",
    "win:debug:overview": "powershell -ExecutionPolicy Bypass -File scripts/windows/debug-overview.ps1",
    "win:debug:web:open": "powershell -ExecutionPolicy Bypass -File scripts/windows/debug-web-open.ps1",
    "win:debug:web:fill": "powershell -ExecutionPolicy Bypass -File scripts/windows/debug-web-fill.ps1",
    "win:debug:web:click": "powershell -ExecutionPolicy Bypass -File scripts/windows/debug-web-click.ps1",
    "win:debug:web:preview": "powershell -ExecutionPolicy Bypass -File scripts/windows/debug-web-preview.ps1",
    "win:debug:web:submit": "powershell -ExecutionPolicy Bypass -File scripts/windows/debug-web-submit.ps1",
    "win:debug:web:extract": "powershell -ExecutionPolicy Bypass -File scripts/windows/debug-web-extract.ps1",
    "win:debug:mail:draft": "powershell -ExecutionPolicy Bypass -File scripts/windows/debug-mail-draft.ps1",
    "win:debug:mail:search": "powershell -ExecutionPolicy Bypass -File scripts/windows/debug-mail-search.ps1",
    "win:debug:mail:send": "powershell -ExecutionPolicy Bypass -File scripts/windows/debug-mail-send.ps1",
    "win:debug:mail:watch": "powershell -ExecutionPolicy Bypass -File scripts/windows/debug-mail-watch.ps1",
    "win:debug:mail:poll-once": "powershell -ExecutionPolicy Bypass -File scripts/windows/debug-mail-poll-once.ps1",
    "win:debug:agent:run": "powershell -ExecutionPolicy Bypass -File scripts/windows/debug-agent-run.ps1",
    "win:debug:agent:run-loop": "powershell -ExecutionPolicy Bypass -File scripts/windows/debug-agent-run-loop.ps1",
    "win:test:agent:prompt": "powershell -ExecutionPolicy Bypass -File scripts/windows/test-agent-prompt.ps1",
    "win:test:mail:draft-self": "powershell -ExecutionPolicy Bypass -File scripts/windows/test-mail-draft-self.ps1",
    "win:test:mail:search-ae-school": "powershell -ExecutionPolicy Bypass -File scripts/windows/test-mail-search-ae-school.ps1",
    "win:test:agent:mail-draft-self": "powershell -ExecutionPolicy Bypass -File scripts/windows/test-agent-mail-draft-self.ps1",
    "win:test:agent:mail-search-ae-school": "powershell -ExecutionPolicy Bypass -File scripts/windows/test-agent-mail-search-ae-school.ps1",
    "win:test:web:naver-stock-fill": "powershell -ExecutionPolicy Bypass -File scripts/windows/test-web-naver-stock-fill.ps1",
    "win:test:web:naver-stock-click": "powershell -ExecutionPolicy Bypass -File scripts/windows/test-web-naver-stock-click.ps1",
    "win:test:web:naver-stock-submit": "powershell -ExecutionPolicy Bypass -File scripts/windows/test-web-naver-stock-submit.ps1",
    "win:test:web:naver-stock-extract": "powershell -ExecutionPolicy Bypass -File scripts/windows/test-web-naver-stock-extract.ps1",
    "win:test:agent:web-naver-stock": "powershell -ExecutionPolicy Bypass -File scripts/windows/test-agent-web-naver-stock.ps1",
    "win:test:agent:web-naver-stock-direct": "powershell -ExecutionPolicy Bypass -File scripts/windows/test-agent-web-naver-stock-direct.ps1",
    "win:test:agent:scenario:naver-news": "powershell -ExecutionPolicy Bypass -File scripts/windows/test-agent-scenario-naver-news.ps1",
    "win:test:agent:scenario:current-page-summary": "powershell -ExecutionPolicy Bypass -File scripts/windows/test-agent-scenario-current-page-summary.ps1",
    "win:test:agent:scenario:current-page-actions": "powershell -ExecutionPolicy Bypass -File scripts/windows/test-agent-scenario-current-page-actions.ps1"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.35",
    "ai": "^6.0.116",
    "fastify": "^5.4.0",
    "yaml": "^2.8.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
