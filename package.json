{
  "name": "enterprise-agent-orchestration",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "node --import tsx apps/orchestrator/src/server.ts",
    "demo": "node --import tsx apps/orchestrator/src/demo.ts",
    "outlook:poller": "node --import tsx workers/outlook-worker/src/poller.ts",
    "test": "node scripts/run-tests.mjs"
  },
  "dependencies": {
    "fastify": "^5.4.0",
    "playwright-core": "^1.58.2",
    "yaml": "^2.8.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
